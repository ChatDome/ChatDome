[Unit]
Description=ChatDome AI Host Security Assistant
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/chatdome
ExecStart=/opt/chatdome/venv/bin/chatdome-server --config /opt/chatdome/config.yaml
Restart=on-failure
RestartSec=5
User=root
Group=root
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
