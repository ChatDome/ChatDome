    echo "5) Show environment profile"
    echo "0) Back"
    echo
    read -r -p "Select: " choice
    case "$choice" in
      1) run_cli status; pause ;;
      2) restart_service_with_result; pause ;;
      3) stop_service_with_result; pause ;;
