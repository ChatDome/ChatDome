#!/usr/bin/env bash
set -uo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
CLI="$ROOT_DIR/chatdome-cli.py"
SERVICE_NAME="chatdome"
SERVICE_PATH="${CHATDOME_SERVICE_PATH:-/etc/systemd/system/${SERVICE_NAME}.service}"
COMMAND_PATH="${CHATDOME_COMMAND_PATH:-/usr/local/bin/chatdome}"
CONFIG_FILE="${CHATDOME_CONFIG:-/etc/chatdome/config.yaml}"
CONFIG_DIR="$(dirname "$CONFIG_FILE")"
DATA_DIR="${CHATDOME_DATA_DIR:-/var/lib/chatdome}"
VENV_ROOT="${CHATDOME_VENV_ROOT:-$DATA_DIR/venvs}"
UPDATE_STATE_DIR="$DATA_DIR/update"
LOG_DIR="${CHATDOME_LOG_DIR:-/var/log/chatdome}"
LOG_FILE="${CHATDOME_LOG_FILE:-$LOG_DIR/chatdome.log}"
SENTINEL_LOG_FILE="${CHATDOME_SENTINEL_LOG_FILE:-$LOG_DIR/sentinel.log}"
RUN_DIR="${CHATDOME_RUN_DIR:-/run/chatdome}"
UPDATE_LOCK_FILE="${CHATDOME_UPDATE_LOCK_FILE:-/run/lock/chatdome-update.lock}"
UPDATE_RUNTIME_LOG="${CHATDOME_UPDATE_RUNTIME_LOG:-$LOG_DIR/update-runtime-check.log}"
EXPECTED_ORIGIN_URL="${CHATDOME_ORIGIN_URL:-https://github.com/ChatDome/ChatDome.git}"

export CHATDOME_CONFIG="$CONFIG_FILE"
export CHATDOME_DATA_DIR="$DATA_DIR"
export CHATDOME_LOG_DIR="$LOG_DIR"
export CHATDOME_LOG_FILE="$LOG_FILE"
export CHATDOME_SENTINEL_LOG_FILE="$SENTINEL_LOG_FILE"
export CHATDOME_RUN_DIR="$RUN_DIR"

if command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
else
  PYTHON_BIN="python"
fi

pause() {
  echo
  read -r -p "Press Enter to continue..." _
}

run_cli() {
  if [[ -x "$ROOT_DIR/venv/bin/python" ]]; then
    "$ROOT_DIR/venv/bin/python" "$CLI" "$@"
  else
    "$PYTHON_BIN" "$CLI" "$@"
  fi
}

prompt_value() {
  local var_name="$1"
  local prompt="$2"
  local default="${3-}"
  local value
  if ! read -r -p "$prompt" value; then
    echo "Cancelled."
    return 1
  fi
  [[ -z "$value" ]] && value="$default"
  printf -v "$var_name" '%s' "$value"
}

prompt_secret() {
  local var_name="$1"
  local prompt="$2"
  local value
  if ! read -r -s -p "$prompt" value; then
    echo
    echo "Cancelled."
    return 1
  fi
  echo
  printf -v "$var_name" '%s' "$value"
}

configure_openai_profile() {
  local profile profile_state model base_url api_key overwrite confirm
  local existing_mode="" existing_model="" existing_base_url="" fingerprint=""
  local -a args
  trap 'printf "\n"; echo "Cancelled."; return 130' INT

  prompt_value profile "Profile name [my-openai-profile]: " "my-openai-profile" || return $?
  profile_state="$(run_cli llm-profile-state "$profile")" || return 1
  if [[ "$profile_state" == "exists" ]]; then
    existing_mode="$(run_cli llm-profile-info "$profile" --field api-mode)" || return 1
    existing_model="$(run_cli llm-profile-info "$profile" --field model)" || return 1
    existing_base_url="$(run_cli llm-profile-info "$profile" --field base-url)" || return 1
    fingerprint="$(run_cli llm-profile-info "$profile" --field fingerprint)" || return 1
    echo "Profile already exists: $profile"
    echo "- type: $existing_mode"
    echo "- model: $existing_model"
    echo "- address: $existing_base_url"
    read -r -p "Overwrite this profile? [y/N] " overwrite
    case "${overwrite,,}" in
      y|yes) ;;
      *) echo "Cancelled."; return 0 ;;
    esac
  fi

  [[ "$existing_mode" == "openai_api" ]] || existing_model=""
  [[ "$existing_mode" == "openai_api" ]] || existing_base_url=""
  prompt_value model "Model [${existing_model:-gpt-4o}]: " "${existing_model:-gpt-4o}" || return $?
  prompt_value base_url "Base URL [${existing_base_url:-https://api.openai.com/v1}]: " "${existing_base_url:-https://api.openai.com/v1}" || return $?
  if [[ "$existing_mode" == "openai_api" ]]; then
    prompt_secret api_key "API Key (blank = keep current): " || return $?
  else
    prompt_secret api_key "API Key: " || return $?
  fi

  if [[ "$profile_state" == "exists" ]]; then
    read -r -p "Update profile '$profile'? [y/N] " confirm
  else
    read -r -p "Add profile '$profile'? [y/N] " confirm
  fi
  case "${confirm,,}" in
    y|yes) ;;
    *) echo "Cancelled."; return 0 ;;
  esac

  args=(set-openai --profile "$profile" --model "$model" --base-url "$base_url" --api-key-stdin)
  if [[ "$profile_state" == "exists" ]]; then
    args+=(--overwrite --expected-profile-fingerprint "$fingerprint")
  fi
  printf '%s\n' "$api_key" | run_cli "${args[@]}"
  pause
}

configure_codex_profile() {
  local profile profile_state overwrite confirm fingerprint=""
  local existing_mode="" existing_model="" existing_base_url=""
  local -a args
  trap 'printf "\n"; echo "Cancelled."; return 130' INT

  prompt_value profile "Profile name [codex]: " "codex" || return $?
  profile_state="$(run_cli llm-profile-state "$profile")" || return 1
  if [[ "$profile_state" == "exists" ]]; then
    existing_mode="$(run_cli llm-profile-info "$profile" --field api-mode)" || return 1
    existing_model="$(run_cli llm-profile-info "$profile" --field model)" || return 1
    existing_base_url="$(run_cli llm-profile-info "$profile" --field base-url)" || return 1
    fingerprint="$(run_cli llm-profile-info "$profile" --field fingerprint)" || return 1
    echo "Profile already exists: $profile"
    echo "- type: $existing_mode"
    echo "- model: $existing_model"
    echo "- address: $existing_base_url"
    read -r -p "Overwrite this profile? [y/N] " overwrite
    case "${overwrite,,}" in
      y|yes) ;;
      *) echo "Cancelled."; return 0 ;;
    esac
  else
    read -r -p "Add Codex profile '$profile'? [y/N] " confirm
    case "${confirm,,}" in
      y|yes) ;;
      *) echo "Cancelled."; return 0 ;;
    esac
  fi

  args=(codex-login --profile "$profile")
  if [[ "$profile_state" == "exists" ]]; then
    args+=(--overwrite --expected-profile-fingerprint "$fingerprint")
  fi
  run_cli "${args[@]}"
  pause
}

delete_llm_profile() {
  local profile active confirm
  trap 'printf "\n"; echo "Cancelled."; return 130' INT

  run_cli llm-list
  echo
  prompt_value profile "Profile to delete: " || return $?
  active="$(run_cli llm-profile-info "$profile" --field active)" || { pause; return 1; }
  if [[ "$active" == "true" ]]; then
    echo "Switch LLM before deleting this profile."
    pause
    return 0
  fi
  read -r -p "Delete profile '$profile'? [y/N] " confirm
  case "${confirm,,}" in
    y|yes) run_cli delete-profile "$profile" ;;
    *) echo "Cancelled." ;;
  esac
  pause
}

systemctl_available() {
  command -v systemctl >/dev/null 2>&1
}

service_action() {
  local action="$1"
  if systemctl_available; then
    run_as_root systemctl "$action" "$SERVICE_NAME"
  else
    bash "$ROOT_DIR/scripts/start.sh" "$action"
  fi
}

service_is_active() {
  if systemctl_available; then
    systemctl is-active --quiet "$SERVICE_NAME"
  else
    bash "$ROOT_DIR/scripts/start.sh" status >/dev/null 2>&1
  fi
}

stop_service_with_result() {
  if ! service_is_active; then
    echo "ℹ️ ChatDome is already stopped."
    return 0
  fi
  if ! service_action stop >/dev/null 2>&1 || service_is_active; then
    echo "❌ Stop failed. Run: sudo systemctl status $SERVICE_NAME"
    return 1
  fi
  echo "✅ ChatDome stopped."
}

start_service_with_result() {
  if service_action start >/dev/null 2>&1 && wait_for_health; then
    echo "✅ ChatDome started and healthy."
    return 0
  fi
  echo "❌ Start failed. Check $LOG_FILE."
  return 1
}

restart_service_with_result() {
  if service_action restart >/dev/null 2>&1 && wait_for_health; then
    echo "✅ ChatDome restarted and healthy."
    return 0
  fi
  echo "❌ Restart failed. Check $LOG_FILE."
  return 1
}

disable_service_with_result() {
  if ! systemctl_available; then
    stop_service_with_result
    echo "ℹ️ No systemd service is installed."
    return
  fi
  if ! service_is_active && ! systemctl is-enabled --quiet "$SERVICE_NAME"; then
    echo "ℹ️ ChatDome service is already stopped and disabled."
    return 0
  fi
  if ! run_as_root systemctl disable --now "$SERVICE_NAME" >/dev/null 2>&1; then
    echo "❌ Disable failed. Run: sudo systemctl status $SERVICE_NAME"
    return 1
  fi
  if service_is_active || systemctl is-enabled --quiet "$SERVICE_NAME"; then
    echo "❌ Disable incomplete. Run: sudo systemctl disable --now $SERVICE_NAME"
    return 1
  fi
  echo "✅ ChatDome service stopped and disabled. Config and data were retained."
}

safe_removal_directory() {
  local path="$1" resolved relative
  resolved="$(readlink -m -- "$path")" || return 1
  [[ "$resolved" == /* ]] || return 1
  [[ "$resolved" != "${HOME:-}" ]] || return 1
  case "$resolved" in
    /|/bin|/boot|/dev|/etc|/home|/lib|/lib64|/opt|/root|/run|/sbin|/srv|/tmp|/usr|/usr/local|/var|/var/lib|/var/log) return 1 ;;
  esac
  relative="${resolved#/}"
  [[ "$relative" == */* ]]
}

permanently_remove_chatdome() {
  local confirmation path
  echo "This permanently deletes ChatDome:"
  echo "- service unit: $SERVICE_PATH"
  echo "- command: $COMMAND_PATH"
  echo "- program: $ROOT_DIR"
  echo "- config: $CONFIG_DIR"
  echo "- data: $DATA_DIR"
  echo "- logs: $LOG_DIR"
  echo
  read -r -p "Type DELETE to continue: " confirmation
  if [[ "$confirmation" != "DELETE" ]]; then
    echo "Cancelled."
    return 0
  fi

  for path in "$ROOT_DIR" "$CONFIG_DIR" "$DATA_DIR" "$LOG_DIR"; do
    if ! safe_removal_directory "$path"; then
      echo "Removal stopped: unsafe path: $path"
      return 1
    fi
  done
  if [[ "$(basename -- "$SERVICE_PATH")" != "chatdome.service" ]]; then
    echo "Removal stopped: unsafe service path: $SERVICE_PATH"
    return 1
  fi
  if [[ "$(basename -- "$COMMAND_PATH")" != "chatdome" ]]; then
    echo "Removal stopped: unsafe command path: $COMMAND_PATH"
    return 1
  fi

  if systemctl_available; then
    if service_is_active || systemctl is-enabled --quiet "$SERVICE_NAME"; then
      if ! run_as_root systemctl disable --now "$SERVICE_NAME" >/dev/null 2>&1; then
        echo "Removal stopped: could not stop and disable ChatDome."
        return 1
      fi
    fi
    run_as_root rm -f "$SERVICE_PATH" || return 1
    run_as_root systemctl daemon-reload || return 1
  else
    stop_service_with_result || return 1
  fi

  run_as_root rm -f "$COMMAND_PATH" || return 1
  run_as_root rm -rf "$CONFIG_DIR" "$DATA_DIR" "$LOG_DIR" || return 1
  run_as_root rm -rf "$ROOT_DIR" || return 1
  echo "ChatDome was permanently removed."
  exit 0
}

