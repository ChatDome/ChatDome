run_as_root() {
  if [[ "${EUID}" -eq 0 || "${CHATDOME_NO_SUDO:-0}" == "1" ]]; then
    "$@"
  else
    sudo "$@"
  fi
}

prepare_runtime_layout() {
  run_as_root install -d -m 0750 "$CONFIG_DIR" "$DATA_DIR" "$LOG_DIR" "$UPDATE_STATE_DIR" || return 1

  if [[ ! -f "$CONFIG_FILE" ]]; then
    if [[ -f "$ROOT_DIR/config.yaml" ]]; then
      run_as_root cp -p "$ROOT_DIR/config.yaml" "$CONFIG_FILE" || return 1
    else
      run_as_root cp "$ROOT_DIR/config.example.yaml" "$CONFIG_FILE" || return 1
    fi
  fi
  run_as_root chmod 600 "$CONFIG_FILE" || return 1

  if [[ -d "$ROOT_DIR/chat_data" && ! -L "$ROOT_DIR/chat_data" ]]; then
    run_as_root cp -a "$ROOT_DIR/chat_data/." "$DATA_DIR/" || return 1
  fi
  if [[ -f "$DATA_DIR/chatdome.log" ]]; then
    if [[ ! -f "$LOG_FILE" ]]; then
      run_as_root mv "$DATA_DIR/chatdome.log" "$LOG_FILE" || return 1
    else
      run_as_root rm -f "$DATA_DIR/chatdome.log" || return 1
    fi
  fi
  run_as_root touch "$LOG_FILE" "$SENTINEL_LOG_FILE" || return 1
  run_as_root chmod 0640 "$LOG_FILE" "$SENTINEL_LOG_FILE" || return 1
}

cleanup_legacy_runtime_layout() {
  run_as_root rm -f "$ROOT_DIR/config.yaml" || return 1
  if [[ -d "$ROOT_DIR/chat_data" && ! -L "$ROOT_DIR/chat_data" ]]; then
    run_as_root rm -rf "$ROOT_DIR/chat_data" || return 1
  fi
}

backup_systemd_unit() {
  systemctl_available || return 0
  if [[ -f "$SERVICE_PATH" ]]; then
    run_as_root cp -p "$SERVICE_PATH" "$UPDATE_STATE_DIR/chatdome.service.rollback" || return 1
  else
    run_as_root rm -f "$UPDATE_STATE_DIR/chatdome.service.rollback" || return 1
  fi
}

install_systemd_unit() {
  systemctl_available || return 0
  local runtime_python="${1:-$ROOT_DIR/venv/bin/python}"
  local candidate="$UPDATE_STATE_DIR/chatdome.service.update"
  cat >"$candidate" <<UNIT
[Unit]
Description=ChatDome AI Host Security Assistant
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=$DATA_DIR
ExecStart=$runtime_python -m chatdome.main --config $CONFIG_FILE
Restart=on-failure
RestartSec=5
User=root
Group=root
Environment=PYTHONUNBUFFERED=1
Environment=CHATDOME_CONFIG=$CONFIG_FILE
Environment=CHATDOME_DATA_DIR=$DATA_DIR
Environment=CHATDOME_LOG_DIR=$LOG_DIR
Environment=CHATDOME_LOG_FILE=$LOG_FILE
Environment=CHATDOME_SENTINEL_LOG_FILE=$SENTINEL_LOG_FILE
Environment=CHATDOME_RUN_DIR=$RUN_DIR
RuntimeDirectory=chatdome
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
UNIT
  run_as_root install -m 0644 "$candidate" "$SERVICE_PATH" || return 1
  run_as_root systemctl daemon-reload || return 1
  rm -f "$candidate"
}

restore_systemd_unit() {
  systemctl_available || return 0
  local backup="$UPDATE_STATE_DIR/chatdome.service.rollback"
  if [[ -f "$backup" ]]; then
    run_as_root install -m 0644 "$backup" "$SERVICE_PATH" || return 1
  else
    run_as_root rm -f "$SERVICE_PATH" || return 1
  fi
  run_as_root systemctl daemon-reload
}

wait_for_rollback_health() {
  local attempt
  for attempt in $(seq 1 10); do
    if systemctl_available; then
      systemctl is-active --quiet "$SERVICE_NAME" && return 0
    else
      local pid_file="$RUN_DIR/chatdome.pid"
      local pid=""
      [[ -f "$pid_file" ]] && pid="$(cat "$pid_file" 2>/dev/null || true)"
      [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1 && return 0
    fi
    sleep 1
  done
  return 1
}

normalize_git_url() {
  local value="${1%/}"
  value="${value%.git}"
  printf '%s' "$value"
}

wait_for_health() {
  local python_bin="$ROOT_DIR/venv/bin/python"
  local attempt
  for attempt in $(seq 1 30); do
    if systemctl_available; then
      if systemctl is-active --quiet "$SERVICE_NAME" && "$python_bin" "$CLI" health-check >/dev/null 2>&1; then
        return 0
      fi
    elif "$python_bin" "$CLI" health-check >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

rollback_update() {
  local old_commit="$1"
  local reason="$2"
  local restart_after_rollback="${3:-1}"
  local candidate_venv="${4:-}"
  local previous_venv="${5:-}"
  local venv_switched="${6:-0}"
  local legacy_rollback="$ROOT_DIR/.venv-rollback"

  echo "❌ Update failed: $reason"
  echo "Restoring $old_commit..."
  service_action stop >/dev/null 2>&1 || true
  if ! restore_systemd_unit; then
    echo "❌ Rollback failed: cannot restore the systemd unit."
    return 1
  fi
  if ! git -C "$ROOT_DIR" reset --hard "$old_commit" || ! git -C "$ROOT_DIR" clean -fd; then
    echo "❌ Rollback failed. Run: git -C $ROOT_DIR reset --hard $old_commit"
    return 1
  fi

  if [[ "$venv_switched" == "1" ]]; then
    rm -f "$ROOT_DIR/venv"
    if [[ -d "$legacy_rollback" && ! -L "$legacy_rollback" ]]; then
      if ! mv "$legacy_rollback" "$ROOT_DIR/venv"; then
        echo "❌ Rollback failed: cannot restore the Python environment."
        return 1
      fi
    elif [[ -n "$previous_venv" && -x "$previous_venv/bin/python" ]]; then
      if ! ln -s "$previous_venv" "$ROOT_DIR/venv"; then
        echo "❌ Rollback failed: cannot restore the Python environment link."
        return 1
      fi
    fi
  fi
  if [[ -n "$candidate_venv" && -d "$candidate_venv" ]]; then
    run_as_root rm -rf "$candidate_venv" || true
  fi
  if [[ ! -x "$ROOT_DIR/venv/bin/python" ]]; then
    echo "❌ Rollback failed: Python environment is missing."
    return 1
  fi
  if [[ "$restart_after_rollback" != "1" ]]; then
    echo "✅ Restored ChatDome: $old_commit"
    echo "⚠️ ChatDome remains stopped. Fix $CONFIG_FILE before starting it."
    return 1
  fi
  if ! service_action restart || ! wait_for_rollback_health; then
    echo "❌ Rollback failed: service health check failed. Check $LOG_FILE."
    return 1
  fi
  echo "✅ Restored ChatDome: $old_commit"
  return 1
}

cleanup_versioned_venvs() {
  local current_venv="$1" previous_venv="${2:-}" path
  [[ -d "$VENV_ROOT" ]] || return 0
  for path in "$VENV_ROOT"/*; do
    [[ -d "$path" ]] || continue
    if [[ "$path" != "$current_venv" && "$path" != "$previous_venv" ]]; then
      run_as_root rm -rf "$path" || return 1
    fi
  done
}
update_chatdome() (
  local answer actual_origin old_commit target_commit update_python candidate_python version runtime_check_output
  local previous_venv="" candidate_venv=""
  local legacy_rollback="$ROOT_DIR/.venv-rollback"
  local venv_switched=0
  local config_was_valid=0
  local candidate_config_valid=0

  if ! command -v flock >/dev/null 2>&1; then
    echo "❌ Update failed: install flock from the util-linux package."
    return 1
  fi
  exec 9>"$UPDATE_LOCK_FILE" || {
    echo "❌ Update failed: cannot open $UPDATE_LOCK_FILE."
    return 1
  }
  if ! flock -n 9; then
    echo "❌ Another ChatDome update is running."
    return 1
  fi

  if ! prepare_runtime_layout; then
    echo "❌ Update failed: cannot prepare runtime directories."
    return 1
  fi

  update_python="$ROOT_DIR/venv/bin/python"
  if [[ ! -x "$update_python" ]]; then
    echo "❌ Python environment not found. Run: sudo bash $ROOT_DIR/install.sh"
    return 1
  fi
  actual_origin="$(git -C "$ROOT_DIR" remote get-url origin 2>/dev/null || true)"
  if [[ "$(normalize_git_url "$actual_origin")" != "$(normalize_git_url "$EXPECTED_ORIGIN_URL")" ]]; then
    echo "❌ Update failed: set origin to $EXPECTED_ORIGIN_URL"
    return 1
  fi

  old_commit="$(git -C "$ROOT_DIR" rev-parse HEAD)" || {
    echo "❌ Update failed: cannot read the current commit."
    return 1
  }

  echo "Checking origin/main..."
  if ! git -C "$ROOT_DIR" fetch --prune origin '+refs/heads/main:refs/remotes/origin/main'; then
    echo "❌ Update failed: cannot fetch origin/main."
    return 1
  fi
  target_commit="$(git -C "$ROOT_DIR" rev-parse refs/remotes/origin/main)" || {
    echo "❌ Update failed: cannot read origin/main."
    return 1
  }
  if [[ "$old_commit" == "$target_commit" ]]; then
    echo "目前已经是最新版本：${old_commit:0:12}"
    return 0
  fi
  if [[ ! "$target_commit" =~ ^[0-9a-f]{40,64}$ ]]; then
    echo "❌ Update failed: invalid origin/main commit."
    return 1
  fi
  candidate_venv="$VENV_ROOT/$target_commit"

  echo "Update available: ${old_commit:0:12} -> ${target_commit:0:12}"
  echo "Tracked local changes and untracked non-ignored files will be removed."
  read -r -p "Continue? [y/N] " answer
  case "${answer,,}" in
    y|yes) ;;
    *) echo "Cancelled."; return 0 ;;
  esac

  if [[ -L "$ROOT_DIR/venv" ]]; then
    previous_venv="$(readlink -f "$ROOT_DIR/venv")"
    if [[ -z "$previous_venv" || ! -x "$previous_venv/bin/python" ]]; then
      echo "❌ Update failed: current Python environment link is invalid."
      return 1
    fi
  elif [[ ! -d "$ROOT_DIR/venv" ]]; then
    echo "❌ Update failed: current Python environment is missing."
    return 1
  fi
  if [[ -e "$legacy_rollback" ]]; then
    echo "❌ Update failed: recovery directory exists: $legacy_rollback"
    return 1
  fi

  printf '%s\n' "$old_commit" >"$UPDATE_STATE_DIR/previous_commit"
  if ! backup_systemd_unit; then
    echo "❌ Update failed: cannot back up the systemd unit."
    return 1
  fi

  if "$update_python" "$CLI" validate-config; then
    config_was_valid=1
  else
    echo "⚠️ Configuration is invalid. ChatDome will remain stopped after the update."
  fi

  if ! service_action stop; then
    echo "❌ Update failed: cannot stop ChatDome."
    return 1
  fi

  echo "Replacing local repository files with origin/main..."
  if ! git -C "$ROOT_DIR" reset --hard origin/main; then
    rollback_update "$old_commit" "cannot reset to origin/main." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
    return 1
  fi
  if ! git -C "$ROOT_DIR" clean -fd; then
    rollback_update "$old_commit" "cannot remove untracked files." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
    return 1
  fi

  run_as_root mkdir -p "$VENV_ROOT" || {
    rollback_update "$old_commit" "cannot prepare versioned Python environments." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
    return 1
  }
  if [[ -e "$candidate_venv" ]]; then
    run_as_root rm -rf "$candidate_venv" || {
      rollback_update "$old_commit" "cannot clear the candidate Python environment." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
      return 1
    }
  fi
  if ! "$PYTHON_BIN" -m venv "$candidate_venv"; then
    rollback_update "$old_commit" "cannot create the candidate Python environment." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
    return 1
  fi
  candidate_python="$candidate_venv/bin/python"
  if ! "$candidate_python" -m ensurepip --upgrade; then
    rollback_update "$old_commit" "cannot initialize pip." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
    return 1
  fi
  if ! "$candidate_python" -m pip install --no-cache-dir --upgrade pip setuptools wheel; then
    rollback_update "$old_commit" "cannot update Python packaging tools." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
    return 1
  fi
  if ! "$candidate_python" -m pip install -e "$ROOT_DIR/controlplane"; then
    rollback_update "$old_commit" "dependency installation failed." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
    return 1
  fi
  if "$candidate_python" "$CLI" validate-config; then
    candidate_config_valid=1
  elif [[ "$config_was_valid" == "1" ]]; then
    rollback_update "$old_commit" "configuration validation failed." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
    return 1
  fi

  run_as_root rm -f "$UPDATE_RUNTIME_LOG" || true
  if ! runtime_check_output="$("$candidate_python" -m chatdome.main --help 2>&1)"; then
    echo "Candidate runtime check failed:"
    printf '%s\n' "$runtime_check_output"
    printf '%s\n' "$runtime_check_output" | run_as_root tee "$UPDATE_RUNTIME_LOG" >/dev/null || true
    if command -v systemd-cat >/dev/null 2>&1; then
      printf '%s\n' "$runtime_check_output" | systemd-cat -t chatdome-update || true
    elif command -v logger >/dev/null 2>&1; then
      printf '%s\n' "$runtime_check_output" | logger -t chatdome-update || true
    fi
    rollback_update "$old_commit" "candidate Python environment cannot start ChatDome. Details: $UPDATE_RUNTIME_LOG" "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
    return 1
  fi

  if [[ -L "$ROOT_DIR/venv" ]]; then
    rm -f "$ROOT_DIR/venv" || {
      rollback_update "$old_commit" "cannot replace the current Python environment link." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
      return 1
    }
  else
    if ! mv "$ROOT_DIR/venv" "$legacy_rollback"; then
      rollback_update "$old_commit" "cannot preserve the legacy Python environment." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
      return 1
    fi
  fi
  if ! ln -s "$candidate_venv" "$ROOT_DIR/venv"; then
    if [[ -d "$legacy_rollback" ]]; then
      mv "$legacy_rollback" "$ROOT_DIR/venv" || true
    elif [[ -n "$previous_venv" ]]; then
      ln -s "$previous_venv" "$ROOT_DIR/venv" || true
    fi
    rollback_update "$old_commit" "cannot activate the versioned Python environment." "$config_was_valid" "$candidate_venv" "$previous_venv" "0"
    return 1
  fi
  venv_switched=1

  if ! install_systemd_unit "$candidate_python"; then
    rollback_update "$old_commit" "cannot install the systemd unit." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
    return 1
  fi
  if [[ "$config_was_valid" == "1" ]]; then
    if ! service_action restart; then
      rollback_update "$old_commit" "service restart failed." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
      return 1
    fi
    if ! wait_for_health; then
      rollback_update "$old_commit" "service health check failed. Check $LOG_FILE." "$config_was_valid" "$candidate_venv" "$previous_venv" "$venv_switched"
      return 1
    fi
  fi

  if ! cleanup_legacy_runtime_layout; then
    echo "⚠️ Update completed. Remove $ROOT_DIR/config.yaml and $ROOT_DIR/chat_data after verifying backups."
  fi
  run_as_root rm -f "$UPDATE_STATE_DIR/chatdome.service.rollback" || true
  if [[ -d "$legacy_rollback" && ! -L "$legacy_rollback" ]]; then
    run_as_root rm -rf "$legacy_rollback" || true
  fi
  if ! cleanup_versioned_venvs "$candidate_venv" "$previous_venv"; then
    echo "⚠️ Update completed, but older Python environments could not be removed."
  fi
  version="$(git -C "$ROOT_DIR" rev-parse --short HEAD)"
  echo "✅ ChatDome updated: $version"
  if [[ "$config_was_valid" != "1" ]]; then
    if [[ "$candidate_config_valid" == "1" ]]; then
      echo "ℹ️ ChatDome remains stopped. Start it from the menu."
    else
      echo "⚠️ Fix $CONFIG_FILE, then start ChatDome from the menu."
    fi
  fi
)
maintenance_menu() {
  while true; do
    show_header
    echo "System Maintenance"
    echo "1) Update ChatDome"
    echo "2) Disable / uninstall"
    echo "0) Back"
    echo
    read -r -p "Select: " choice
    case "$choice" in
      1)
        update_chatdome
        pause
        ;;
      2)
        echo "1) Stop and disable service (keep config and data)"
        echo "2) Permanently remove ChatDome (delete config and data)"
        echo "0) Back"
        read -r -p "Select: " uninstall_choice
        case "$uninstall_choice" in
          1) disable_service_with_result ;;
          2) permanently_remove_chatdome ;;
          0) continue ;;
        esac
        pause
        ;;
      0) return ;;
    esac
  done
}

setup_guidance() {
  run_cli status || true
  echo
  echo "Configure ChatDome:"
  echo "- LLM: chatdome -> AI model management"
  echo "- Telegram: chatdome -> Telegram configuration"
  echo "- Service: chatdome -> Start service"
  echo "- Check: chatdome doctor"
}

show_usage() {
  cat <<'USAGE'
Usage: chatdome [command]

Commands:
  hello    Show terminal chat entry
  status   Show installation status
  doctor   Check local configuration
  setup    Show setup steps

Run "chatdome" to open the management menu.
USAGE
}

main_menu() {
  if ! prepare_runtime_layout; then
    echo "❌ Cannot prepare ChatDome runtime directories."
    exit 1
  fi
  run_cli ensure-config >/dev/null
  while true; do
    trap 'printf "\n"; exit 130' INT
    show_header
    echo "1) Lets chat"
    echo "2) Start service"
    echo "3) Service management"
    echo "4) AI model management"
    echo "5) Telegram configuration"
    echo "6) Sentinel management"
    echo "7) Agent security policy"
    echo "8) System maintenance"
    echo "0) Exit"
    echo
    read -r -p "Select: " choice
    case "$choice" in
      1) lets_chat ;;
      2) start_service ;;
      3) service_menu ;;
      4) llm_menu ;;
      5) telegram_menu ;;
      6) sentinel_menu ;;
      7) agent_menu ;;
      8) maintenance_menu ;;
      0) exit 0 ;;
    esac
  done
}

case "${1:-}" in
  "") main_menu ;;
  hello) run_cli hello ;;
  status) run_cli status ;;
  doctor) run_cli doctor ;;
  setup) setup_guidance ;;
  help|--help|-h) show_usage ;;
  --update) update_chatdome ;;
  --stop) stop_service_with_result ;;
  --disable-service) disable_service_with_result ;;
  *)
    echo "Unknown command: $1"
    echo
    show_usage
    exit 2
    ;;
esac
